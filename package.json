{
  "name": "capital-cohort",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev": "APP_VARIANT=development expo start --dev-client",
    "android": "expo start --android",
    "android:dev": "APP_VARIANT=development expo start --android --dev-client",
    "ios": "expo start --ios",
    "ios:dev": "APP_VARIANT=development expo start --ios --dev-client",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --forceExit",
    "build:dev": "eas build --profile development",
    "build:dev:android": "eas build -p android --profile development",
    "build:dev:ios": "eas build -p ios --profile development",
    "build:preview": "eas build --profile preview",
    "build:preview:android": "eas build -p android --profile preview",
    "build:preview:ios": "eas build -p ios --profile preview",
    "build:prod": "eas build --profile production",
    "build:prod:android": "eas build -p android --profile production",
    "build:prod:ios": "eas build -p ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "expo": "^55.0.10-canary-20260327-0789fbc",
    "expo-constants": "55.0.10-canary-20260327-0789fbc",
    "expo-dev-client": "55.0.20-canary-20260327-0789fbc",
    "expo-device": "^55.0.11-canary-20260327-0789fbc",
    "expo-document-picker": "55.0.10-canary-20260327-0789fbc",
    "expo-file-system": "55.0.13-canary-20260327-0789fbc",
    "expo-linking": "55.0.10-canary-20260327-0789fbc",
    "expo-localization": "55.0.10-canary-20260327-0789fbc",
    "expo-location": "55.1.5-canary-20260327-0789fbc",
    "expo-notifications": "^55.0.15-canary-20260327-0789fbc",
    "expo-router": "55.0.9-canary-20260327-0789fbc",
    "expo-sharing": "55.0.15-canary-20260327-0789fbc",
    "expo-status-bar": "55.0.5-canary-20260327-0789fbc",
    "expo-task-manager": "^55.0.11-canary-20260327-0789fbc",
    "i18next": "^25.8.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "55.0.12-canary-20260327-0789fbc",
    "typescript": "~5.9.2"
  },
  "private": true
}
